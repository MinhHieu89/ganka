# Docker image tag (set by CI/CD, or use 'latest')
IMAGE_TAG=latest

# SQL Server connection string (external server)
DB_CONNECTION_STRING=Server=your-sql-server;Database=Ganka28;User Id=sa;Password=YourPassword;MultipleActiveResultSets=true;TrustServerCertificate=True

# JWT configuration
JWT_KEY=YourSecureKeyAtLeast32CharactersLong
JWT_ISSUER=Ganka28
JWT_AUDIENCE=Ganka28App

# CORS allowed origin (e.g., https://ganka.yourdomain.com)
CORS_ORIGIN=

# Port mapping (optional, defaults shown)
BACKEND_PORT=5255
FRONTEND_PORT=3000
